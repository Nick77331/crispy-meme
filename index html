<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Geometry Dash Universe</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #222; color: white; text-align: center; margin: 0; padding: 20px; }
        h1 { color: #2ecc71; text-transform: uppercase; letter-spacing: 2px; }
        .game-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; max-width: 1000px; margin: 40px auto; }
        .game-card { background: #333; border-radius: 15px; padding: 20px; border: 2px solid transparent; transition: 0.3s; }
        .game-card:hover { border-color: #2ecc71; transform: translateY(-5px); background: #444; }
        .game-card img { width: 100px; height: 100px; border-radius: 20%; margin-bottom: 15px; }
        .game-card h3 { margin: 10px 0; }
        .btn { display: inline-block; padding: 10px 20px; background: #2ecc71; color: #fff; text-decoration: none; border-radius: 5px; font-weight: bold; margin-top: 10px; }
        .btn:hover { background: #27ae60; }
    </style>
</head>
<body>

    <h1>Geometry Dash Games</h1>
    <p>Explore all official titles by <a href="https://www.robtopgames.com/" style="color: #2ecc71;">RobTop Games</a>.</p>

    <div class="game-grid">
        <!-- Geometry Dash Full -->
        <div class="game-card">
            <img src="https://wikimedia.org" alt="GD">
            <h3>Geometry Dash</h3>
            <p>The original rhythm-based platformer.</p>
            <a href="https://steampowered.com" class="btn">Play Now</a>
        </div>

        <!-- Geometry Dash Meltdown -->
        <div class="game-card">
            <img src="https://mzstatic.com" alt="Meltdown">
            <h3>Meltdown</h3>
            <p>Three unique levels with F-777 music.</p>
            <a href="https://apple.com" class="btn">App Store</a>
        </div>

        <!-- Geometry Dash World -->
        <div class="game-card">
            <img src="https://mzstatic.com" alt="World">
            <h3>World</h3>
            <p>10 short levels across two islands.</p>
            <a href="https://google.com" class="btn">Play Store</a>
        </div>

        <!-- Geometry Dash SubZero -->
        <div class="game-card">
            <img src="https://mzstatic.com" alt="SubZero">
            <h3>SubZero</h3>
            <p>Experience the cool side of Dash.</p>
            <a href="https://apple.com" class="btn">Get App</a>
        </div>
    </div>

</body>
</html>
